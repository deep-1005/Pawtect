# MongoDB Connection
# For local MongoDB (default):
MONGO_URI=mongodb://127.0.0.1:27017/pawtect

# For MongoDB Atlas (cloud):
# MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/pawtect

# Server Port
PORT=5000

# JWT Secret (change this to a random string)
JWT_SECRET=your_jwt_secret_key_here

# Environment
NODE_ENV=development
